# ===========================================
# Environment
# ===========================================
ENVIRONMENT=development  # development | test | production

# ===========================================
# Telegram
# ===========================================
TG__WEBHOOK_USE=False
TG__WEBHOOK_PATH=/telegram
TG__BOT_TOKEN=YOUR_BOT_TOKEN_HERE  # Получите от @BotFather
TG__ADMIN_IDS=[YOUR_TELEGRAM_USER_ID]  # Ваш Telegram ID (узнать: @userinfobot)

# ===========================================
# WebHook
# ===========================================
WEBHOOK__URL=https://YOUR_DOMAIN.COM  # Ваш домен или IP с https
WEBHOOK__HOST=0.0.0.0
WEBHOOK__PORT=8000
WEBHOOK__SECRET=CHANGE_ME_TO_RANDOM_SECRET

# ===========================================
# Database
# ===========================================
DB__HOST=db
DB__PORT=5432
DB__USER=default
DB__PASSWORD=change_me_password
DB__NAME=telegram_bot_template

# ===========================================
# Redis
# ===========================================
REDIS__HOST=redis
REDIS__PORT=6379
REDIS__USER=default
REDIS__PASSWORD=change_me_redis_password
REDIS__DB=0

# ===========================================
# API Settings (FastAPI for Mini Apps)
# ===========================================
API__HOST=0.0.0.0
API__PORT=8000
API__DEBUG=false

# ===========================================
# WebApp Settings
# ===========================================
WEBAPP__URL=https://YOUR_DOMAIN.COM  # Тот же домен для Mini App
